# Evolution API v2.3.7 - EasyPanel
#
# Antes de usar:
# 1. Substitua `wpplytics` pelo nome real do projeto no EasyPanel.
# 2. Substitua as senhas abaixo pelas geradas no Postgres e Redis.
# 3. Gere uma AUTHENTICATION_API_KEY forte.
# 4. Nao use `latest`.

# === SERVIDOR ===
# O EasyPanel preenche o dominio primario automaticamente.
SERVER_URL=https://$(PRIMARY_DOMAIN)
SERVER_PORT=8080

# === AUTENTICACAO ===
AUTHENTICATION_API_KEY=CHANGE_ME_WITH_A_LONG_RANDOM_KEY
AUTHENTICATION_EXPOSE_IN_FETCH_INSTANCES=false

# === INSTANCIAS ===
DEL_INSTANCE=false
DEL_TEMP_INSTANCES=false

# === LOGS ===
LOG_LEVEL=ERROR,WARN,INFO
LOG_COLOR=true
LOG_BAILEYS=error

# === BANCO DE DADOS ===
DATABASE_ENABLED=true
DATABASE_PROVIDER=postgresql
DATABASE_CONNECTION_URI=postgres://postgres:CHANGE_ME_POSTGRES_PASSWORD@wpplytics_evolution-postgres:5432/evolution
DATABASE_CONNECTION_CLIENT_NAME=evolution_v2
DATABASE_SAVE_DATA_INSTANCE=true
DATABASE_SAVE_DATA_NEW_MESSAGE=true
DATABASE_SAVE_MESSAGE_UPDATE=true
DATABASE_SAVE_DATA_CONTACTS=true
DATABASE_SAVE_DATA_CHATS=true
DATABASE_SAVE_DATA_LABELS=true
DATABASE_SAVE_DATA_HISTORIC=true

# === CACHE REDIS ===
CACHE_REDIS_ENABLED=true
CACHE_REDIS_URI=redis://default:CHANGE_ME_REDIS_PASSWORD@wpplytics_evolution-redis:6379
CACHE_REDIS_PREFIX_KEY=evolution_v2
CACHE_REDIS_SAVE_INSTANCES=false
CACHE_LOCAL_ENABLED=false

# === WEBSOCKET ===
WEBSOCKET_ENABLED=true
WEBSOCKET_GLOBAL_EVENTS=false

# === WEBHOOK GLOBAL ===
WEBHOOK_GLOBAL_ENABLED=false

# === QRCODE ===
QRCODE_LIMIT=30
QRCODE_COLOR=#175197

# === SESSAO ===
CONFIG_SESSION_PHONE_CLIENT=Evolution API
CONFIG_SESSION_PHONE_NAME=Chrome

# === PROVIDER ===
PROVIDER_ENABLED=false
PROVIDER_HOST=127.0.0.1
PROVIDER_PORT=5656
PROVIDER_PREFIX=evolution_v2

# === INTEGRACOES OPCIONAIS ===
S3_ENABLED=false
RABBITMQ_ENABLED=false
CHATWOOT_ENABLED=false
OPENAI_ENABLED=false
DIFY_ENABLED=false

# === IDIOMA ===
LANGUAGE=pt-BR
